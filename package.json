{
  "name": "glow-ds",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./components": {
      "import": "./dist/components.js",
      "types": "./dist/lib/components.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens.js",
      "types": "./dist/lib/tokens.d.ts"
    },
    "./tailwind-preset": "./lib/tailwind-preset.js"
  },
  "files": [
    "dist",
    "lib/tailwind-preset.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "prebuild": "npm run generate",
    "prebuild:lib": "npm run generate",
    "generate": "npm run generate:manifest-json && npm run generate:hex-map",
    "generate:manifest-json": "node scripts/generate-manifest-json.cjs",
    "generate:hex-map": "node scripts/generate-hex-map.cjs",
    "validate": "node scripts/validate-tokens.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons:rename": "node scripts/rename-svgs.cjs",
    "icons:scan-colors": "node scripts/scan-svg-colors.cjs",
    "icons:generate-line": "npx @svgr/cli --config-file scripts/svgr.config.cjs --out-dir src/components/Icon/icons/line ./figma-icons/line/",
    "icons:generate-solid": "npx @svgr/cli --config-file scripts/svgr.config.cjs --out-dir src/components/Icon/icons/solid ./figma-icons/solid/",
    "icons:generate-specialty": "npx @svgr/cli --config-file scripts/svgr-specialty.config.cjs --out-dir src/components/Icon/icons/specialty ./figma-icons/specialty/",
    "icons:generate-profile": "npx @svgr/cli --config-file scripts/svgr-specialty.config.cjs --out-dir src/components/Icon/icons/profile ./figma-icons/profile/",
    "icons:index": "node scripts/generate-icon-index.cjs",
    "icons:build": "npm run icons:rename && npm run icons:generate-line && npm run icons:generate-solid && npm run icons:generate-specialty && npm run icons:generate-profile && npm run icons:index"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@svgr/cli": "^8.1.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
