{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "erasableSyntaxOnly": true
  },
  "include": [
    "lib/**/*.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "tokens/**/*.ts"
  ],
  "exclude": [
    "src/docs",
    "src/App.tsx",
    "src/main.tsx"
  ]
}
